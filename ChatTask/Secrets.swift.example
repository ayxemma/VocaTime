import Foundation

/// Optional app secrets (gitignored copy: `Secrets.swift`).
///
/// **Backend API keys** are not stored in the iOS client. Transcription and parsing go through
/// `BackendConfig` → your ChatTask server. Add client-side secrets here only if a future feature needs them.

enum Secrets {
    // Reserved for non-OpenAI secrets (e.g. analytics) — leave empty if unused.
    static let placeholder = ""
}
